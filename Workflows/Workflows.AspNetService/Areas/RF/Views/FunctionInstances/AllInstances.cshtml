@using MessagePack;
@model WorkflowInstancesModel
@{
    ViewBag.Title = $"All Instances for [{Model.WorkflowName}]";
}
<div class="w3-container w3-margin">
    <header class="w3-text-blue-gray">
        <h2 class="w3-margin-top">
            <b>
                <span class="w3-text-indigo">@Model.WorkflowName</span> Instances
            </b>
        </h2>
    </header>
   @* <p class="w3-col m6 l4">
        <select class="w3-select" name="option">
            <option value="" disabled selected>Choose a Status</option>
            <option value="1">In Progress (@Model.InProgressCount)</option>
            <option value="2">Error (@Model.FailedCount)</option>
            <option value="3">Completed (@Model.CompletedCount)</option>
        </select>
    </p>*@

    <table class="w3-table-all w3-padding-32" style="width: 100%;table-layout: fixed;">
        <thead>
            <tr class="w3-indigo">
                <th>ID</th>
                <th>Status</th>
                <th width="35%">State Object</th>
                <th>Waiting For</th>
                <th>History</th>
                <th>Created</th>
                <th>Updated</th>
            </tr>
        </thead>
        @foreach (var instance in Model.Instances)
        {
            <tr>
                <td>@instance.WorkflowInstance.Id</td>
                <td class="w3-text-@instance.StateColor">@instance.WorkflowInstance.Status</td>
                <td>
                    <span class="JsonObject" style=" word-wrap: break-word;">
                        @MessagePackSerializer.ConvertToJson(instance.WorkflowInstance.StateObjectValue)
                    </span>
                </td>
                <td>@instance.CurrentWait?.Name</td>
                <td>
                    <a target="_blank" href="~/RF/WorkflowInstances/WorkflowInstance?instanceId=@instance.Id" class="w3-text-blue">
                        @instance.WaitsCount Waits
                    </a>
                </td>
                <td>@instance.WorkflowInstance.Created.ToLocalTime()</td>
                <td>@instance.WorkflowInstance.Modified.ToLocalTime()</td>
            </tr>
        }
        
    </table>
</div>